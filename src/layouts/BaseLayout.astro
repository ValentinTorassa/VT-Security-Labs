---
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  /** Ancho del contenido principal. `wide` para landing, `prose` para labs. */
  width?: "default" | "wide" | "prose";
  /** Imagen para compartir en redes (relativa al sitio). */
  image?: string;
}

const {
  title,
  description = "Labs prácticos en español para entender Linux, redes, backend, cloud y ciberseguridad de verdad. Aprendé construyendo evidencia.",
  width = "default",
  image = "/og-default.png",
} = Astro.props;

const fullTitle =
  title === "VT Security Labs" ? title : `${title} · VT Security Labs`;

const mainWidth =
  width === "wide"
    ? "max-w-6xl"
    : width === "prose"
      ? "max-w-3xl"
      : "max-w-5xl";

// URLs absolutas para SEO y tarjetas sociales.
const site = Astro.site ?? new URL("https://securitylabs.valentorassa.com");
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL(image, site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "VT Security Labs",
  url: site.href,
  description,
  inLanguage: "es-AR",
  author: {
    "@type": "Person",
    name: "Valentín Torassa Colombero",
    url: "https://valentorassa.com",
  },
};
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/jpeg" href="/vt-youtube.jpg" />
    <link rel="apple-touch-icon" href="/vt-youtube.jpg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07090a" />
    <link rel="canonical" href={canonical.href} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="VT Security Labs"
      href={new URL("/rss.xml", site).href}
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VT Security Labs" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body class="bg-base-950 min-h-screen antialiased">
    <a
      href="#contenido"
      class="bg-term-green text-base-950 sr-only rounded px-3 py-2 font-mono text-sm focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
    >
      Saltar al contenido
    </a>

    <Header />

    <main
      id="contenido"
      class:list={["mx-auto w-full px-5 sm:px-6", mainWidth]}
    >
      <slot />
    </main>

    <Footer />
  </body>
</html>
