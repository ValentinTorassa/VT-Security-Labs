---
// Motor único de preguntas. Dos modos:
//   - "instant": feedback inmediato al tocar cada opción (quiz dentro de un lab).
//   - "graded": respondés todo y calificás al final, con puntaje y aprobado/no
//     (examen de ruta o de certificación).
// Client-side, sin backend. Para examen usá el wrapper Exam.astro.
import type { ExamQuestion } from "../data/questions";

interface Props {
  questions: ExamQuestion[];
  title?: string;
  mode?: "instant" | "graded";
  /** Solo en "graded": puntaje mínimo para aprobar (porcentaje). */
  passScore?: number;
  /** Solo en "graded": bajada opcional bajo el título. */
  subtitle?: string;
  /** Solo en "graded": clave para recordar si ya se aprobó (ej: ruta:cloud-produccion). */
  storeKey?: string;
}

const {
  questions,
  mode = "instant",
  passScore = 70,
  subtitle,
  storeKey,
  title = mode === "graded" ? "Examen" : "Comprobá lo que entendiste",
} = Astro.props;

const uid = "quiz-" + Math.random().toString(36).slice(2, 9);
const accent = mode === "graded" ? "term-green" : "term-cyan";
---

<section
  class:list={[
    "not-prose my-8 rounded-xl border p-5",
    mode === "graded"
      ? "border-base-700 bg-base-850/50 sm:p-6"
      : "border-term-cyan/30 bg-term-cyan/5",
  ]}
  data-quiz
  data-mode={mode}
  data-pass={passScore}
  data-store-key={storeKey}
  id={uid}
>
  <header class="flex flex-wrap items-baseline justify-between gap-2">
    <h3
      class:list={[
        "flex items-center gap-2 font-mono font-semibold",
        mode === "graded" ? "text-base-50 text-lg" : `text-${accent} text-sm`,
      ]}
    >
      <span aria-hidden="true" class={`text-${accent}`}>
        {mode === "graded" ? "▣" : "▸"}
      </span>
      {title}
    </h3>
    {
      mode === "graded" ? (
        <p class="text-base-400 font-mono text-xs">
          {questions.length} preguntas · aprobás con {passScore}%
        </p>
      ) : (
        <p
          class="text-base-400 font-mono text-xs"
          data-quiz-score
          data-total={questions.length}
        >
          0 / {questions.length} correctas
        </p>
      )
    }
  </header>
  {subtitle && <p class="text-base-400 mt-1 text-sm">{subtitle}</p>}

  <ol class="mt-4 space-y-6">
    {
      questions.map((item, qi) => (
        <li class="list-none" data-question data-answer={item.answer}>
          <p class="text-base-100 text-sm font-medium">
            <span class={`font-mono text-${accent}`}>{qi + 1}.</span> {item.q}
          </p>
          <div class="mt-3 grid gap-2" role="radiogroup">
            {item.options.map((opt, oi) => (
              <button
                type="button"
                data-option
                data-index={oi}
                aria-pressed="false"
                class="border-base-700 bg-base-850/60 text-base-200 hover:border-base-500 aria-pressed:border-term-cyan aria-pressed:bg-term-cyan/10 flex items-center gap-2.5 rounded-lg border px-3 py-2 text-left text-sm transition-colors disabled:cursor-default"
              >
                <span
                  class="text-base-500 font-mono text-xs"
                  data-mark
                  aria-hidden="true"
                >
                  {String.fromCharCode(97 + oi)}
                </span>
                <span>{opt}</span>
              </button>
            ))}
          </div>
          {item.explain && (
            <p
              class="border-base-700 bg-base-900 text-base-300 mt-2 hidden rounded-md border px-3 py-2 text-xs leading-relaxed"
              data-explain
            >
              {item.explain}
            </p>
          )}
        </li>
      ))
    }
  </ol>

  {
    mode === "graded" && (
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <button type="button" data-quiz-grade class="btn-primary">
          Calificar examen
        </button>
        <button type="button" data-quiz-reset class="btn-ghost hidden">
          Reiniciar ↻
        </button>
        <p
          class="hidden font-mono text-sm font-semibold"
          data-quiz-result
          aria-live="polite"
        />
        <p
          class="text-term-green hidden font-mono text-xs"
          data-quiz-passed-note
        >
          ✓ Ya lo aprobaste antes
        </p>
      </div>
    )
  }
</section>

<script>
  import { isExamPassed, setExamPassed } from "../scripts/progress";

  document.querySelectorAll<HTMLElement>("[data-quiz]").forEach((quiz) => {
    const mode = quiz.dataset.mode ?? "instant";
    const questions = Array.from(
      quiz.querySelectorAll<HTMLElement>("[data-question]"),
    );

    const markCorrect = (btn: HTMLButtonElement, symbol: string) => {
      btn.classList.add("border-term-green", "bg-term-green/10");
      btn.classList.remove(
        "border-base-700",
        "bg-base-850/60",
        "bg-base-900/60",
      );
      const mark = btn.querySelector<HTMLElement>("[data-mark]");
      if (mark) {
        mark.textContent = symbol;
        mark.classList.add("text-term-green");
      }
    };
    const markWrong = (btn: HTMLButtonElement, symbol: string) => {
      btn.classList.add("border-term-red", "bg-term-red/10");
      btn.classList.remove(
        "border-base-700",
        "bg-base-850/60",
        "bg-base-900/60",
      );
      const mark = btn.querySelector<HTMLElement>("[data-mark]");
      if (mark) {
        mark.textContent = symbol;
        mark.classList.add("text-term-red");
      }
    };
    const reveal = (question: HTMLElement) =>
      question
        .querySelector<HTMLElement>("[data-explain]")
        ?.classList.remove("hidden");

    if (mode === "instant") {
      const scoreEl = quiz.querySelector<HTMLElement>("[data-quiz-score]");
      const total = Number(scoreEl?.dataset.total ?? 0);
      let correct = 0;

      questions.forEach((question) => {
        const answer = Number(question.dataset.answer);
        const options =
          question.querySelectorAll<HTMLButtonElement>("[data-option]");
        let answered = false;

        options.forEach((btn) => {
          btn.addEventListener("click", () => {
            if (answered) return;
            answered = true;
            const idx = Number(btn.dataset.index);
            if (idx === answer) correct += 1;
            options.forEach((b) => {
              b.disabled = true;
              const i = Number(b.dataset.index);
              if (i === answer) markCorrect(b, "✓");
              else if (i === idx) markWrong(b, "✕");
            });
            reveal(question);
            if (scoreEl)
              scoreEl.textContent = `${correct} / ${total} correctas`;
          });
        });
      });
      return;
    }

    // mode === "graded"
    const pass = Number(quiz.dataset.pass ?? 70);
    const storeKey = quiz.dataset.storeKey || "";
    const gradeBtn = quiz.querySelector<HTMLButtonElement>("[data-quiz-grade]");
    const resetBtn = quiz.querySelector<HTMLButtonElement>("[data-quiz-reset]");
    const result = quiz.querySelector<HTMLElement>("[data-quiz-result]");
    const passedNote = quiz.querySelector<HTMLElement>(
      "[data-quiz-passed-note]",
    );
    let graded = false;

    if (storeKey && isExamPassed(storeKey)) {
      passedNote?.classList.remove("hidden");
    }

    const select = (question: HTMLElement, btn: HTMLButtonElement) => {
      if (graded) return;
      question
        .querySelectorAll<HTMLButtonElement>("[data-option]")
        .forEach((b) => b.setAttribute("aria-pressed", "false"));
      btn.setAttribute("aria-pressed", "true");
      question.dataset.selected = btn.dataset.index;
    };

    const grade = () => {
      if (graded) return;
      let correct = 0;
      questions.forEach((question) => {
        const answer = Number(question.dataset.answer);
        const selected =
          question.dataset.selected !== undefined
            ? Number(question.dataset.selected)
            : -1;
        if (selected === answer) correct += 1;
        question
          .querySelectorAll<HTMLButtonElement>("[data-option]")
          .forEach((b) => {
            b.disabled = true;
            const i = Number(b.dataset.index);
            if (i === answer) markCorrect(b, "✓");
            else if (i === selected) markWrong(b, "✕");
          });
        reveal(question);
      });
      graded = true;
      const score = Math.round((correct / questions.length) * 100);
      const ok = score >= pass;
      if (ok && storeKey) {
        setExamPassed(storeKey, true);
        passedNote?.classList.remove("hidden");
      }
      if (result) {
        result.textContent = `${ok ? "✓ Aprobado" : "✕ No alcanzó"} · ${correct}/${questions.length} (${score}%)`;
        result.classList.remove("hidden");
        result.classList.add(ok ? "text-term-green" : "text-term-red");
      }
      gradeBtn?.classList.add("hidden");
      resetBtn?.classList.remove("hidden");
      quiz.scrollIntoView({ behavior: "smooth", block: "nearest" });
    };

    const reset = () => {
      graded = false;
      questions.forEach((question) => {
        delete question.dataset.selected;
        question
          .querySelectorAll<HTMLButtonElement>("[data-option]")
          .forEach((b) => {
            b.disabled = false;
            b.setAttribute("aria-pressed", "false");
            b.classList.remove(
              "border-term-green",
              "bg-term-green/10",
              "border-term-red",
              "bg-term-red/10",
            );
            b.classList.add("border-base-700", "bg-base-850/60");
            const mark = b.querySelector<HTMLElement>("[data-mark]");
            mark?.classList.remove("text-term-green", "text-term-red");
            if (mark)
              mark.textContent = String.fromCharCode(
                97 + Number(b.dataset.index),
              );
          });
        question
          .querySelector<HTMLElement>("[data-explain]")
          ?.classList.add("hidden");
      });
      result?.classList.add("hidden");
      result?.classList.remove("text-term-green", "text-term-red");
      gradeBtn?.classList.remove("hidden");
      resetBtn?.classList.add("hidden");
    };

    questions.forEach((question) => {
      question
        .querySelectorAll<HTMLButtonElement>("[data-option]")
        .forEach((btn) =>
          btn.addEventListener("click", () => select(question, btn)),
        );
    });
    gradeBtn?.addEventListener("click", grade);
    resetBtn?.addEventListener("click", reset);
  });
</script>
