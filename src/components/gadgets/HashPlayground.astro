---
// Playground de hashing y encoding. Client-side, sin backend.
// Diferencia clave: base64 es reversible (encoding), SHA-256 NO (hash de una vía).
const uid = "hash-" + Math.random().toString(36).slice(2, 9);
---

<section
  class="not-prose border-term-green/30 bg-term-green/5 my-8 rounded-xl border p-5"
  data-hash
  id={uid}
>
  <h3
    class="text-term-green flex items-center gap-2 font-mono text-sm font-semibold"
  >
    <span aria-hidden="true">▸</span> Playground: base64 vs SHA-256
  </h3>
  <p class="text-base-400 mt-1 text-xs">
    Escribí texto y compará. <strong class="text-base-300">base64</strong> es encoding
    reversible (no protege nada). <strong class="text-base-300">SHA-256</strong> es
    un hash de una sola vía: no se puede deshacer. Todo corre en tu navegador.
  </p>

  <textarea
    rows="3"
    placeholder="escribí algo…"
    data-hash-input
    aria-label="Texto de entrada"
    class="border-base-600 bg-base-850 text-base-100 placeholder:text-base-500 focus:border-term-green mt-4 w-full resize-y rounded-md border px-3 py-2 font-mono text-sm outline-none"
    >password123</textarea
  >

  <div class="mt-4 space-y-3">
    <div>
      <div class="flex items-center justify-between">
        <p class="text-base-400 font-mono text-xs">base64 (reversible)</p>
        <button
          type="button"
          data-hash-copy="b64"
          class="text-base-500 hover:text-term-green font-mono text-xs"
          >copiar</button
        >
      </div>
      <pre
        class="border-base-700 bg-base-900 text-base-100 mt-1 overflow-x-auto rounded-lg border p-3 font-mono text-xs break-all"
        data-hash-b64>
      </pre>
    </div>
    <div>
      <div class="flex items-center justify-between">
        <p class="text-base-400 font-mono text-xs">SHA-256 (una vía)</p>
        <button
          type="button"
          data-hash-copy="sha"
          class="text-base-500 hover:text-term-green font-mono text-xs"
          >copiar</button
        >
      </div>
      <pre
        class="border-base-700 bg-base-900 text-term-green mt-1 overflow-x-auto rounded-lg border p-3 font-mono text-xs break-all"
        data-hash-sha>
      </pre>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-hash]").forEach((root) => {
    const input = root.querySelector<HTMLTextAreaElement>("[data-hash-input]");
    const b64El = root.querySelector<HTMLElement>("[data-hash-b64]");
    const shaEl = root.querySelector<HTMLElement>("[data-hash-sha]");
    if (!input || !b64El || !shaEl) return;

    const toB64 = (s: string) => {
      const bytes = new TextEncoder().encode(s);
      let bin = "";
      bytes.forEach((b) => (bin += String.fromCharCode(b)));
      return btoa(bin);
    };

    const sha256 = async (s: string) => {
      const buf = await crypto.subtle.digest(
        "SHA-256",
        new TextEncoder().encode(s),
      );
      return Array.from(new Uint8Array(buf))
        .map((b) => b.toString(16).padStart(2, "0"))
        .join("");
    };

    const update = async () => {
      const text = input.value;
      b64El.textContent = text ? toB64(text) : "—";
      shaEl.textContent = text ? await sha256(text) : "—";
    };

    input.addEventListener("input", update);

    root
      .querySelectorAll<HTMLButtonElement>("[data-hash-copy]")
      .forEach((btn) => {
        btn.addEventListener("click", async () => {
          const which = btn.dataset.hashCopy;
          const el = which === "sha" ? shaEl : b64El;
          const txt = el.textContent ?? "";
          if (!txt || txt === "—") return;
          try {
            await navigator.clipboard.writeText(txt);
            const prev = btn.textContent;
            btn.textContent = "✓ copiado";
            setTimeout(() => (btn.textContent = prev), 1200);
          } catch {
            /* clipboard no disponible */
          }
        });
      });

    update();
  });
</script>
