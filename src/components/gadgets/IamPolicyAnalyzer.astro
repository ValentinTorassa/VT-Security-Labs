---
// Evaluador de políticas IAM. Client-side, sin backend.
// Modela la lógica real de AWS: Deny explícito gana, si no hay Allow → denegado.
const uid = "iam-" + Math.random().toString(36).slice(2, 9);
---

<section
  class="not-prose border-term-amber/30 bg-term-amber/5 my-8 rounded-xl border p-5"
  data-iam
  id={uid}
>
  <h3
    class="text-term-amber flex items-center gap-2 font-mono text-sm font-semibold"
  >
    <span aria-hidden="true">▸</span> Evaluador de políticas IAM
  </h3>
  <p class="text-base-400 mt-1 text-xs">
    Armá una política y probá una acción. AWS evalúa así: un <code
      class="text-base-300">Deny</code
    > explícito gana siempre; si nada te lo permite, estás denegado por defecto. Los
    comodines <code class="text-base-300">*</code> valen.
  </p>

  <!-- Statements -->
  <div class="mt-4 space-y-2" data-iam-list></div>

  <button
    type="button"
    data-iam-add
    class="border-base-700 text-base-200 hover:border-term-amber mt-2 rounded-md border px-3 py-1.5 font-mono text-xs transition-colors"
    >+ Agregar statement</button
  >

  <!-- Test -->
  <div
    class="border-base-700 bg-base-900 mt-4 flex flex-wrap items-center gap-2 rounded-lg border p-4"
  >
    <span class="text-base-400 font-mono text-xs">¿Se permite</span>
    <input
      type="text"
      placeholder="s3:GetObject"
      value="s3:GetObject"
      data-iam-test
      aria-label="Acción a evaluar"
      class="border-base-600 bg-base-850 text-base-50 focus:border-term-amber w-44 rounded-md border px-2.5 py-1.5 font-mono text-xs outline-none"
    />
    <span class="text-base-400 font-mono text-xs">?</span>
    <button
      type="button"
      data-iam-eval
      class="bg-term-amber text-base-950 ml-auto rounded-md px-4 py-1.5 font-mono text-xs font-semibold transition-transform hover:-translate-y-0.5"
      >Evaluar</button
    >
  </div>

  <div
    class="mt-3 hidden rounded-lg border p-4 font-mono text-sm"
    data-iam-result
    aria-live="polite"
  >
  </div>
</section>

<script>
  type Effect = "Allow" | "Deny";
  type Stmt = { effect: Effect; action: string };

  document.querySelectorAll<HTMLElement>("[data-iam]").forEach((root) => {
    const list = root.querySelector<HTMLElement>("[data-iam-list]");
    const addBtn = root.querySelector<HTMLButtonElement>("[data-iam-add]");
    const testInput = root.querySelector<HTMLInputElement>("[data-iam-test]");
    const evalBtn = root.querySelector<HTMLButtonElement>("[data-iam-eval]");
    const result = root.querySelector<HTMLElement>("[data-iam-result]");
    if (!list || !addBtn || !testInput || !evalBtn || !result) return;

    const stmts: Stmt[] = [
      { effect: "Allow", action: "s3:*" },
      { effect: "Deny", action: "s3:DeleteObject" },
    ];

    const render = () => {
      list.innerHTML = "";
      stmts.forEach((s, i) => {
        const row = document.createElement("div");
        row.className = "flex items-center gap-2";
        row.innerHTML = `
          <select data-effect class="border-base-600 bg-base-850 rounded-md border px-2 py-1.5 font-mono text-xs outline-none ${
            s.effect === "Allow" ? "text-term-green" : "text-term-red"
          }">
            <option value="Allow"${s.effect === "Allow" ? " selected" : ""}>Allow</option>
            <option value="Deny"${s.effect === "Deny" ? " selected" : ""}>Deny</option>
          </select>
          <input data-action type="text" value="${s.action.replace(/"/g, "&quot;")}" placeholder="servicio:Accion" class="border-base-600 bg-base-850 text-base-50 focus:border-term-amber flex-1 rounded-md border px-2.5 py-1.5 font-mono text-xs outline-none" />
          <button type="button" data-del aria-label="Eliminar" class="text-base-500 hover:text-term-red px-2 font-mono text-sm">✕</button>`;
        const sel = row.querySelector<HTMLSelectElement>("[data-effect]")!;
        const act = row.querySelector<HTMLInputElement>("[data-action]")!;
        sel.addEventListener("change", () => {
          s.effect = sel.value as Effect;
          sel.className = sel.className
            .replace(/text-term-(green|red)/, "")
            .trim();
          sel.classList.add(
            s.effect === "Allow" ? "text-term-green" : "text-term-red",
          );
        });
        act.addEventListener("input", () => (s.action = act.value));
        row.querySelector("[data-del]")!.addEventListener("click", () => {
          stmts.splice(i, 1);
          render();
        });
        list.appendChild(row);
      });
    };

    // Convierte un patrón IAM (con *) a regex.
    const matches = (pattern: string, action: string) => {
      const rx = new RegExp(
        "^" +
          pattern
            .trim()
            .replace(/[.+^${}()|[\]\\]/g, "\\$&")
            .replace(/\*/g, ".*") +
          "$",
        "i",
      );
      return rx.test(action.trim());
    };

    const evaluate = () => {
      const action = testInput.value.trim();
      if (!action) return;
      const denied = stmts.some(
        (s) => s.effect === "Deny" && matches(s.action, action),
      );
      const allowed = stmts.some(
        (s) => s.effect === "Allow" && matches(s.action, action),
      );

      let verdict: string, reason: string, cls: string;
      if (denied) {
        verdict = "✕ DENEGADO";
        reason =
          "Un Deny explícito coincide con la acción. El Deny siempre gana.";
        cls = "border-term-red/40 bg-term-red/10 text-term-red";
      } else if (allowed) {
        verdict = "✓ PERMITIDO";
        reason = "Hay un Allow que coincide y ningún Deny lo bloquea.";
        cls = "border-term-green/40 bg-term-green/10 text-term-green";
      } else {
        verdict = "✕ DENEGADO (implícito)";
        reason =
          "Ningún statement permite esta acción. El default de IAM es negar.";
        cls = "border-base-600 bg-base-800 text-base-300";
      }

      result.className = "mt-3 rounded-lg border p-4 font-mono text-sm " + cls;
      result.innerHTML = `<div class="font-bold">${verdict}</div><div class="text-base-300 mt-1 text-xs">${reason}</div>`;
      result.classList.remove("hidden");
    };

    addBtn.addEventListener("click", () => {
      stmts.push({ effect: "Allow", action: "" });
      render();
    });
    evalBtn.addEventListener("click", evaluate);
    testInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") evaluate();
    });

    render();
    evaluate();
  });
</script>
