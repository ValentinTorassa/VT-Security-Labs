---
// Examen: respondés todo y calificás al final. Es el motor Quiz en modo "graded".
import type { ExamQuestion } from "../data/questions";
import Quiz from "./Quiz.astro";

interface Props {
  questions: ExamQuestion[];
  /** Puntaje mínimo para aprobar (porcentaje). */
  passScore?: number;
  title?: string;
  subtitle?: string;
  /** Clave para recordar si ya se aprobó (ej: ruta:cloud-produccion). */
  storeKey?: string;
}
const {
  questions,
  passScore = 70,
  title = "Examen",
  subtitle,
  storeKey,
} = Astro.props;
---

<Quiz
  questions={questions}
  mode="graded"
  passScore={passScore}
  title={title}
  subtitle={subtitle}
  storeKey={storeKey}
/>
