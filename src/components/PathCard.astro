---
import type { LearningPath } from "../data/paths";
import Icon from "./Icon.astro";

interface Props {
  path: LearningPath;
  labCount?: number;
  /** Ids de los labs de la ruta, para calcular progreso en el cliente. */
  labIds?: string[];
}
const { path, labCount, labIds = [] } = Astro.props;
---

<a
  href={`/rutas/${path.slug}`}
  class="card group relative flex flex-col overflow-hidden p-5 hover:-translate-y-0.5"
  style={`--accent: ${path.accent}`}
  data-path-card
>
  <span
    class="pointer-events-none absolute inset-x-0 top-0 h-px opacity-60"
    style="background: linear-gradient(to right, transparent, var(--accent), transparent)"
    aria-hidden="true"></span>

  <div class="flex items-center justify-between gap-3">
    <span
      class="flex h-10 w-10 items-center justify-center rounded-lg border"
      style="border-color: color-mix(in srgb, var(--accent) 40%, transparent); color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent)"
    >
      <Icon name={path.icon} size={20} />
    </span>
    <span class="text-base-400 flex items-center gap-2 font-mono text-xs">
      <span>Ruta {String(path.order).padStart(2, "0")}</span>
      {
        typeof labCount === "number" && (
          <>
            <span class="text-base-600">·</span>
            <span>
              {labCount} {labCount === 1 ? "lab" : "labs"}
            </span>
          </>
        )
      }
    </span>
  </div>

  <h3 class="text-base-50 mt-4 text-lg font-semibold transition-colors">
    <span class="group-hover:text-[color:var(--accent)]">{path.title}</span>
  </h3>

  <p class="text-base-300 mt-1.5 text-sm leading-relaxed">{path.tagline}</p>

  <div class="mt-4 flex flex-wrap gap-1.5">
    {
      path.focus
        .slice(0, 4)
        .map((f) => (
          <span class="border-base-700 bg-base-800/60 text-base-400 rounded border px-2 py-0.5 font-mono text-[0.7rem]">
            {f}
          </span>
        ))
    }
  </div>

  <div
    class="border-base-800 mt-4 flex items-center gap-2 border-t pt-3 font-mono text-xs"
  >
    <span style="color: var(--accent)">$</span>
    <span class="text-base-400 truncate">{path.command}</span>
    <span
      class="text-base-500 ml-auto transition-transform group-hover:translate-x-0.5"
      style="color: var(--accent)"
      aria-hidden="true">→</span
    >
  </div>

  {
    labIds.length > 0 && (
      <div
        data-path-progress
        data-lab-ids={labIds.join(",")}
        class="mt-3 hidden"
      >
        <div class="bg-base-800 h-1 w-full overflow-hidden rounded-full">
          <div
            data-path-progress-bar
            class="h-full rounded-full transition-[width] duration-500"
            style="width: 0%; background: var(--accent)"
          />
        </div>
        <p
          data-path-progress-label
          class="text-base-500 mt-1.5 font-mono text-[0.7rem]"
        />
      </div>
    )
  }
</a>

<script>
  import { countDone, onProgress } from "../scripts/progress";

  function hydrate() {
    document
      .querySelectorAll<HTMLElement>("[data-path-progress]")
      .forEach((el) => {
        const ids = (el.dataset.labIds ?? "").split(",").filter(Boolean);
        if (!ids.length) return;
        const done = countDone(ids);
        if (done === 0) {
          el.classList.add("hidden");
          return;
        }
        el.classList.remove("hidden");
        const pct = Math.round((done / ids.length) * 100);
        const bar = el.querySelector<HTMLElement>("[data-path-progress-bar]");
        if (bar) bar.style.width = `${pct}%`;
        const label = el.querySelector<HTMLElement>(
          "[data-path-progress-label]",
        );
        if (label) {
          label.textContent =
            pct === 100
              ? `✓ ruta completada · ${done}/${ids.length}`
              : `${done}/${ids.length} labs · ${pct}%`;
          label.classList.toggle("text-term-green", pct === 100);
        }
      });
  }

  hydrate();
  onProgress(hydrate);
</script>
