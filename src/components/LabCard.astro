---
import type { CollectionEntry } from "astro:content";
import { getPath } from "../data/paths";
import { getContributor, avatarUrl } from "../data/contributors";
import LabLevel from "./LabLevel.astro";

interface Props {
  lab: CollectionEntry<"labs">;
  /** Mostrar el nombre de la ruta (útil en /labs). */
  showPath?: boolean;
}
const { lab, showPath = true } = Astro.props;
const { data } = lab;
const path = getPath(data.path);

const contributor = getContributor(data.contributor);
const contributorName = contributor?.name ?? data.contributor;

const accent = path?.accent ?? "#56d364";
---

<a
  href={`/labs/${lab.id}`}
  class="card group flex flex-col p-5 hover:-translate-y-0.5"
  style={`--accent: ${accent}`}
  data-lab-card
  data-lab-id={lab.id}
  data-title={data.title.toLowerCase()}
  data-path={data.path}
  data-level={data.level}
  data-tags={data.tags.join(" ").toLowerCase()}
>
  <div class="flex items-center justify-between gap-2">
    {
      showPath && path && (
        <span
          class="inline-flex items-center gap-1.5 font-mono text-xs"
          style="color: var(--accent)"
        >
          {path.title}
        </span>
      )
    }
    <div class="ml-auto flex items-center gap-2">
      <span
        class="border-term-green/40 bg-term-green/10 text-term-green hidden items-center rounded-full border px-2 py-0.5 font-mono text-[0.65rem]"
        data-done-badge
      >
        ✓ hecho
      </span>
      <span class="text-base-400 font-mono text-xs">
        {data.estimatedMinutes} min
      </span>
    </div>
  </div>

  <h3
    class="text-base-50 mt-3 text-base leading-snug font-semibold group-hover:text-[color:var(--accent)]"
  >
    {data.title}
  </h3>

  <p class="text-base-300 mt-2 line-clamp-3 text-sm leading-relaxed">
    {data.description}
  </p>

  <div class="border-base-800 mt-4 flex items-center gap-2 border-t pt-3">
    <span
      class="border-base-700 bg-base-800/60 text-base-400 rounded border px-2 py-0.5 font-mono text-[0.7rem]"
    >
      <LabLevel level={data.level} />
    </span>
    {
      data.tags
        .slice(0, 2)
        .map((t) => (
          <span class="text-base-500 font-mono text-[0.7rem]">#{t}</span>
        ))
    }
    <span
      class="text-base-500 ml-auto font-mono transition-transform group-hover:translate-x-0.5"
      style="color: var(--accent)"
      aria-hidden="true">→</span
    >
  </div>

  <!-- Autor del lab: avatar + handle de GitHub (no es un link: la card ya lo es). -->
  <div class="mt-3 flex items-center gap-2">
    <img
      src={avatarUrl(data.contributor, 36)}
      alt=""
      width="18"
      height="18"
      loading="lazy"
      decoding="async"
      class="border-base-700 h-[18px] w-[18px] rounded-full border bg-black"
    />
    <span class="text-base-500 font-mono text-[0.7rem]">
      por <span class="text-base-400">{contributorName}</span>
    </span>
  </div>
</a>
