---
import type { Certification } from "../data/certifications";

interface Props {
  cert: Certification;
}
const { cert } = Astro.props;
---

<a
  href={`/certificaciones/${cert.slug}`}
  class="card group relative flex flex-col overflow-hidden p-5 hover:-translate-y-0.5"
  style={`--accent: ${cert.accent}`}
>
  <span
    class="pointer-events-none absolute inset-x-0 top-0 h-px opacity-60"
    style="background: linear-gradient(to right, transparent, var(--accent), transparent)"
    aria-hidden="true"></span>

  <div class="flex items-center gap-3">
    <span
      class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border font-mono text-sm font-bold tracking-tight"
      style="border-color: color-mix(in srgb, var(--accent) 45%, transparent); color: var(--accent); background: color-mix(in srgb, var(--accent) 12%, transparent)"
    >
      {cert.badge}
    </span>
    <div class="min-w-0">
      <p class="truncate font-mono text-xs" style="color: var(--accent)">
        {cert.code} · {cert.level}
      </p>
      <p class="text-base-500 font-mono text-[0.7rem]">{cert.vendor}</p>
    </div>
  </div>

  <h3
    class="text-base-50 mt-4 text-base leading-snug font-semibold group-hover:text-[color:var(--accent)]"
  >
    {cert.name}
  </h3>

  <p class="text-base-300 mt-2 line-clamp-3 flex-1 text-sm leading-relaxed">
    {cert.summary}
  </p>

  <div
    class="border-base-800 text-base-400 mt-4 flex items-center gap-2 border-t pt-3 font-mono text-xs"
  >
    <span>{cert.exam.length} preguntas de práctica</span>
    <span
      class="ml-auto transition-transform group-hover:translate-x-0.5"
      style="color: var(--accent)"
      aria-hidden="true">→</span
    >
  </div>
</a>
