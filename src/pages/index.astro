---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { paths } from "../data/paths";
import { certifications } from "../data/certifications";

const labs = await getCollection("labs", ({ data }) => !data.draft);
const countFor = (slug: string) =>
  labs.filter((l) => l.data.path === slug).length;

// Pasos del método (la 4ª, "evidencia", en dorado).
const method = [
  {
    icon: "file-text" as const,
    step: "01_",
    title: "Leés",
    body: "La lección explica el mecanismo de fondo, no recetas para copiar y pegar.",
    accent: "var(--color-term-green)",
  },
  {
    icon: "terminal" as const,
    step: "02_",
    title: "Corrés comandos",
    body: "En tu propia máquina, Linux o WSL. Rompés cosas en un entorno seguro.",
    accent: "var(--color-term-green)",
  },
  {
    icon: "flag" as const,
    step: "03_",
    title: "Completás el reto",
    body: "Un enunciado final que te obliga a aplicar lo que entendiste, no a repetir.",
    accent: "var(--color-term-green)",
  },
  {
    icon: "check" as const,
    step: "04_",
    title: "Dejás evidencia",
    body: "Comandos, writeups, diagramas, screenshots, repos. La prueba de que lo hiciste.",
    accent: "var(--color-term-amber)",
  },
];

const audience = [
  {
    icon: "lightbulb" as const,
    title: "Estudiantes y juniors",
    body: "Entrando a ciberseguridad o IT, sin promesas de bootcamp ni atajos.",
  },
  {
    icon: "git-branch" as const,
    title: "Programadores y backend devs",
    body: "Que quieren entender por qué algo falla en producción y no solo en localhost.",
  },
  {
    icon: "server" as const,
    title: "Gente de infra, DevOps y cloud",
    body: "Que quiere dejar de tratar la nube como magia y saber qué pasa por debajo.",
  },
  {
    icon: "bug" as const,
    title: "Curiosos del bajo nivel",
    body: "Que prefieren entender el mecanismo antes que coleccionar herramientas.",
  },
];

// Listado de rutas para la "ventana de terminal" del hero.
const routeList = paths.map((p) => `${p.slug}/`);

const youtube = "https://www.youtube.com/@vtcibersecurity";
const repo = "https://github.com/ValentinTorassa/VT-Security-Labs";

// Color del chip de nivel de cada certi, derivado de su acento de marca.
const levelChip = (cert: (typeof certifications)[number]) => cert.accent;
---

<BaseLayout title="VT Security Labs" width="wide">
  <!-- Grilla ambiental + glow radial verde detrás del hero (decorativos). -->
  <div
    class="bg-grid pointer-events-none fixed inset-0 -z-10"
    style="mask-image:radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 78%); -webkit-mask-image:radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 78%);"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none fixed top-[-360px] left-1/2 -z-10 h-[700px] w-[1100px] -translate-x-1/2 blur-[20px]"
    style="background:radial-gradient(ellipse at center, color-mix(in srgb, var(--color-term-green) 14%, transparent), transparent 62%);"
    aria-hidden="true"
  >
  </div>

  <!-- ===================== HERO : TERMINAL ===================== -->
  <section
    id="top"
    class="grid items-center gap-12 py-12 lg:grid-cols-[1.02fr_0.98fr] lg:py-16"
  >
    <div>
      <div
        class="border-term-green/35 bg-term-green/[0.06] text-term-green inline-flex items-center gap-2 rounded-full border px-3 py-1.5 font-mono text-xs"
      >
        <span
          class="bg-term-green h-1.5 w-1.5 rounded-full"
          style="box-shadow:0 0 8px var(--color-term-green);"></span>
        plataforma educativa abierta · español
      </div>

      <h1
        class="text-base-50 mt-6 font-mono text-4xl leading-[1.04] font-extrabold tracking-[-0.04em] sm:text-5xl lg:text-[3.6rem]"
      >
        Aprendé los sistemas<br /><span class="text-term-green">de verdad.</span
        >
      </h1>

      <p class="text-base-300 mt-6 max-w-lg text-lg leading-relaxed">
        Labs prácticos de Linux, redes, backend, cloud y ciberseguridad. Leés,
        corrés comandos en tu máquina y dejás <span class="text-base-100"
          >evidencia</span
        >. Sin hype, sin promesas de bootcamp.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="#rutas"
          class="bg-term-green text-base-950 inline-flex items-center gap-2 rounded-[10px] px-5 py-3 font-mono text-sm font-bold transition hover:-translate-y-px hover:brightness-110"
          style="box-shadow:0 0 22px color-mix(in srgb, var(--color-term-green) 30%, transparent);"
        >
          <span class="opacity-60">$</span> empezar a aprender
        </a>
        <a
          href={youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="border-base-600 text-base-100 hover:border-term-green hover:bg-term-green/[0.06] inline-flex items-center gap-2 rounded-[10px] border px-5 py-3 font-mono text-sm font-semibold transition"
        >
          ver el canal ↗
        </a>
      </div>

      <div
        class="text-base-400 mt-8 flex flex-wrap gap-x-7 gap-y-3 font-mono text-xs"
      >
        <span><span class="text-term-green">0{paths.length}</span> rutas</span>
        <span><span class="text-term-green">100%</span> open source</span>
        <span><span class="text-term-green">0</span> login · 0 tracking</span>
      </div>
    </div>

    <!-- Ventana de terminal flotante -->
    <div
      class="[animation:vtFloat_7s_ease-in-out_infinite] overflow-hidden rounded-xl border border-[#30363d] bg-[#0a0e14]"
      style="box-shadow:0 24px 60px -20px rgba(0,0,0,0.8), 0 0 0 1px color-mix(in srgb, var(--color-term-green) 6%, transparent);"
    >
      <div
        class="border-base-700 flex items-center gap-2 border-b bg-[#161b22] px-3.5 py-3"
      >
        <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[#27c93f]"></span>
        <span class="text-base-400 ml-2 font-mono text-xs"
          >vt@labs: ~/rutas</span
        >
      </div>
      <div
        class="text-base-200 px-4 py-5 font-mono text-[13.5px] leading-[1.85]"
      >
        <div>
          <span class="text-term-green">vt@labs</span><span
            class="text-base-400">:~$</span
          > whoami
        </div>
        <div class="text-base-300 pt-0.5 pb-2">
          &gt; No podés defender sistemas que no entendés cómo funcionan.
        </div>
        <div>
          <span class="text-term-green">vt@labs</span><span
            class="text-base-400">:~$</span
          > ls rutas/
        </div>
        <div class="text-term-blue grid grid-cols-2 gap-x-3.5 pt-0.5 pb-2">
          {routeList.map((r) => <span>{r}</span>)}
        </div>
        <div>
          <span class="text-term-green">vt@labs</span><span
            class="text-base-400">:~$</span
          > cat metodo.txt
        </div>
        <div class="text-base-300 pt-0.5 pb-2">
          leés → corrés → completás el reto → <span class="text-term-amber"
            >dejás evidencia</span
          >
        </div>
        <div>
          <span class="text-term-green">vt@labs</span><span
            class="text-base-400">:~$</span
          > ./empezar.sh<span
            class="bg-term-green ml-0.5 inline-block h-4 w-2 [animation:vtBlink_1s_step-end_infinite] align-[-3px]"
          ></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== MÉTODO ===================== -->
  <section id="metodo" class="scroll-mt-20 py-16">
    <div class="mb-2 flex items-baseline gap-3.5">
      <span class="text-term-green font-mono text-sm">// 01</span>
      <h2 class="text-base-50 font-mono text-3xl font-bold tracking-tight">
        Cómo funciona un lab
      </h2>
    </div>
    <p class="text-base-400 mb-10 max-w-2xl text-base leading-relaxed">
      Cada módulo es un lab práctico. No se aprende mirando: se aprende dejando
      rastro de lo que hiciste.
    </p>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        method.map((m) => (
          <div
            class="card p-5 hover:-translate-y-1"
            style={`--accent:${m.accent}; ${m.accent.includes("amber") ? "border-color: color-mix(in srgb, var(--color-term-amber) 40%, transparent);" : ""}`}
          >
            <div class="mb-3.5 flex items-center gap-2.5">
              <span style={`color:${m.accent}`} class="inline-flex">
                <Icon name={m.icon} size={21} strokeWidth={1.6} />
              </span>
              <span class="font-mono text-sm" style={`color:${m.accent}`}>
                {m.step}
              </span>
            </div>
            <div class="text-base-100 mb-2 font-mono text-base font-semibold">
              {m.title}
            </div>
            <p class="text-base-400 text-sm leading-relaxed">{m.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===================== RUTAS ===================== -->
  <section id="rutas" class="scroll-mt-20 py-16">
    <div class="mb-2 flex items-baseline gap-3.5">
      <span class="text-term-green font-mono text-sm">// 02</span>
      <h2 class="text-base-50 font-mono text-3xl font-bold tracking-tight">
        Rutas de aprendizaje
      </h2>
    </div>
    <p class="text-base-400 mb-10 max-w-2xl text-base leading-relaxed">
      Seis caminos que se cruzan. Empezá por donde te haga falta entender mejor.
    </p>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        paths.map((path) => (
          <a
            href={`/rutas/${path.slug}`}
            class="card group hover:border-term-green block p-6 hover:-translate-y-1"
            style={`--accent:${path.accent}`}
          >
            <div class="mb-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span
                  class="flex h-9 w-9 items-center justify-center rounded-[10px] border"
                  style="border-color:color-mix(in srgb, var(--color-term-green) 28%, transparent); background:color-mix(in srgb, var(--color-term-green) 9%, transparent); color:var(--color-term-green)"
                >
                  <Icon name={path.icon} size={19} strokeWidth={1.6} />
                </span>
                <span class="bg-term-green text-base-950 rounded-md px-2.5 py-1 font-mono text-xs font-semibold">
                  {String(path.order).padStart(2, "0")}
                </span>
              </div>
              <span class="text-base-500 font-mono text-xs">~/{path.slug}</span>
            </div>
            <h3 class="text-base-50 group-hover:text-term-green mb-2.5 font-mono text-lg font-bold transition-colors">
              {path.title}
            </h3>
            <p class="text-base-400 mb-4 text-sm leading-relaxed">
              {path.description}
            </p>
            <div class="flex flex-wrap items-center gap-1.5 font-mono text-xs">
              {path.focus.slice(0, 3).map((f) => (
                <span class="text-term-blue bg-term-blue/10 rounded px-2 py-0.5 lowercase">
                  {f}
                </span>
              ))}
              <span class="text-base-500 ml-auto">
                {countFor(path.slug)} labs
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ===================== CERTIFICACIONES ===================== -->
  <section id="certificaciones" class="scroll-mt-20 py-16">
    <div class="mb-2 flex items-baseline gap-3.5">
      <span class="text-term-green font-mono text-sm">// 03</span>
      <h2 class="text-base-50 font-mono text-3xl font-bold tracking-tight">
        Certificaciones
      </h2>
    </div>
    <p class="text-base-400 mb-10 max-w-2xl text-base leading-relaxed">
      VT Labs es gratis y no emite títulos propios. Pero te da la <span
        class="text-base-100">base real</span
      > para encarar las certificaciones que el mercado pide — sin estudiar de memoria.
      Cada ruta apunta a una.
    </p>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        certifications.map((cert) => (
          <a
            href={`/certificaciones/${cert.slug}`}
            class="card group hover:border-term-green block p-5 hover:-translate-y-1"
            style={`--accent:${levelChip(cert)}`}
          >
            <div class="mb-4 flex items-center gap-3.5">
              <span
                class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl border font-mono text-base font-bold"
                style="border-color:color-mix(in srgb, var(--accent) 40%, transparent); background:color-mix(in srgb, var(--accent) 10%, transparent); color:var(--accent)"
              >
                {cert.badge}
              </span>
              <div class="min-w-0">
                <h3 class="text-base-50 mb-0.5 font-mono text-base leading-tight font-bold">
                  {cert.name}
                </h3>
                <p class="text-base-500 text-xs">{cert.vendor}</p>
              </div>
            </div>
            <div class="border-base-700 flex items-center justify-between border-t pt-3.5 font-mono text-xs">
              <span class="text-term-blue">~/{cert.relatedPaths[0]}</span>
              <span
                class="rounded-full border px-2.5 py-1"
                style="border-color:color-mix(in srgb, var(--accent) 25%, transparent); background:color-mix(in srgb, var(--accent) 10%, transparent); color:var(--accent)"
              >
                {cert.level}
              </span>
            </div>
          </a>
        ))
      }
    </div>
    <p class="text-base-500 mt-6 text-xs leading-relaxed">
      VT Security Labs no está afiliado a estas organizaciones; cada logo y
      marca pertenece a su dueño.
    </p>
  </section>

  <!-- ===================== PARA QUIÉN ===================== -->
  <section id="quien" class="scroll-mt-20 py-16">
    <div class="mb-2 flex items-baseline gap-3.5">
      <span class="text-term-green font-mono text-sm">// 04</span>
      <h2 class="text-base-50 font-mono text-3xl font-bold tracking-tight">
        ¿Para quién es?
      </h2>
    </div>
    <p class="text-base-400 mb-10 max-w-2xl text-base leading-relaxed">
      Sin timelines de fantasía. Para gente que prefiere entender el mecanismo
      antes que coleccionar herramientas.
    </p>

    <div class="grid gap-3.5 sm:grid-cols-2">
      {
        audience.map((a) => (
          <div class="card flex gap-4 p-5">
            <span class="text-term-green mt-0.5 inline-flex shrink-0">
              <Icon name={a.icon} size={22} strokeWidth={1.6} />
            </span>
            <div>
              <div class="text-base-100 mb-1.5 font-mono text-base font-semibold">
                {a.title}
              </div>
              <p class="text-base-400 text-sm leading-relaxed">{a.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===================== COMUNIDAD / CTA ===================== -->
  <section id="comunidad" class="scroll-mt-20 py-16">
    <div
      class="border-base-700 relative overflow-hidden rounded-2xl border p-8 sm:p-11"
      style="background:linear-gradient(135deg, var(--color-base-850), var(--color-base-950));"
    >
      <div
        class="pointer-events-none absolute -top-32 -right-20 h-[420px] w-[420px]"
        style="background:radial-gradient(circle, color-mix(in srgb, var(--color-term-green) 14%, transparent), transparent 65%);"
        aria-hidden="true"
      >
      </div>
      <div
        class="relative grid items-center gap-8 lg:grid-cols-[auto_1fr_auto]"
      >
        <div class="relative shrink-0">
          <img
            src="/vt-avatar.png"
            alt="VT Security — mascota pingüino con capucha"
            width="124"
            height="124"
            class="border-base-600 block h-[124px] w-[124px] rounded-2xl border bg-black"
          />
          <span
            class="bg-term-green text-base-950 absolute -right-2 -bottom-2 inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 font-mono text-xs font-semibold"
            style="box-shadow:0 0 14px color-mix(in srgb, var(--color-term-green) 40%, transparent);"
          >
            ● live
          </span>
        </div>
        <div>
          <div
            class="text-term-green mb-3 font-mono text-xs tracking-[0.15em] uppercase"
          >
            // comunidad
          </div>
          <h2
            class="text-base-50 mb-3 font-mono text-2xl font-extrabold tracking-tight sm:text-3xl"
          >
            Seguí los labs en VT Security
          </h2>
          <p class="text-base-300 max-w-xl leading-relaxed">
            Ciberseguridad, Linux y home labs explicados de verdad por Valentín
            Torassa Colombero — Rosario, Argentina. Tutoriales prácticos de
            programación, redes y seguridad. La evidencia se construye haciendo.
          </p>
        </div>
        <div class="flex shrink-0 flex-col gap-2.5">
          <a
            href={youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-term-green text-base-950 inline-flex items-center justify-center gap-2 rounded-[10px] px-5 py-3 font-mono text-sm font-bold whitespace-nowrap transition hover:brightness-110"
            style="box-shadow:0 0 22px color-mix(in srgb, var(--color-term-green) 30%, transparent);"
          >
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M23.5 6.2a3 3 0 0 0-2.12-2.12C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.53A3 3 0 0 0 .5 6.2C0 8.07 0 12 0 12s0 3.93.5 5.8a3 3 0 0 0 2.12 2.12C4.5 20.45 12 20.45 12 20.45s7.5 0 9.38-.53a3 3 0 0 0 2.12-2.12C24 15.93 24 12 24 12s0-3.93-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z"
              ></path></svg
            >
            Suscribirme
          </a>
          <a
            href={repo}
            target="_blank"
            rel="noopener noreferrer"
            class="border-base-600 text-base-100 hover:border-term-green inline-flex items-center justify-center gap-2 rounded-[10px] border px-5 py-3 font-mono text-sm font-semibold whitespace-nowrap transition"
          >
            ★ Star en GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
