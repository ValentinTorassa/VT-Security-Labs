---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LabLayout from "../../components/LabLayout.astro";

export const getStaticPaths = (async () => {
  const labs = await getCollection("labs", ({ data }) => !data.draft);

  // Validación en build: cada id de `nextLabs` tiene que existir (y no ser draft).
  // Un typo rompe el build acá en vez de quedar como un link muerto silencioso.
  const ids = new Set(labs.map((l) => l.id));
  const broken = labs.flatMap((l) =>
    l.data.nextLabs
      .filter((id) => !ids.has(id))
      .map((id) => `  - "${l.id}" → nextLabs: "${id}" no existe`),
  );
  if (broken.length > 0) {
    throw new Error(
      `nextLabs apunta a labs inexistentes (o en draft):\n${broken.join("\n")}`,
    );
  }

  return labs.map((lab) => ({
    params: { slug: lab.id },
    props: { lab },
  }));
}) satisfies GetStaticPaths;

const { lab } = Astro.props;
const { Content } = await render(lab);

const site = Astro.site ?? new URL("https://securitylabs.valentorassa.com");
const labJsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: lab.data.title,
  description: lab.data.description,
  inLanguage: "es-AR",
  url: new URL(`/labs/${lab.id}`, site).href,
  image: new URL(`/og/${lab.id}.png`, site).href,
  keywords: lab.data.tags.join(", "),
  educationalLevel: lab.data.level,
  timeRequired: `PT${lab.data.estimatedMinutes}M`,
  author: {
    "@type": "Person",
    name: "Valentín Torassa Colombero",
    url: "https://valentorassa.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Open Security Labs",
    url: site.href,
  },
};
---

<BaseLayout
  title={lab.data.title}
  description={lab.data.description}
  image={`/og/${lab.id}.png`}
  jsonLd={labJsonLd}
  width="prose"
>
  <LabLayout lab={lab}>
    <Content />
  </LabLayout>
</BaseLayout>
